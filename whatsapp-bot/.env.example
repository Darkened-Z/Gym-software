# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gym_management
DB_USERNAME=root
DB_PASSWORD=

# WhatsApp session / browser
WHATSAPP_SESSION_DIR=./session
WHATSAPP_HEADLESS=true
WHATSAPP_QR=true
WHATSAPP_PUPPETEER_EXECUTABLE_PATH=

# Safety
WHATSAPP_DRY_RUN=false
WHATSAPP_TIMEZONE=Asia/Karachi
WHATSAPP_COUNTRY_CODE=92
WHATSAPP_DEFAULT_GYM_NAME=Your Gym
WHATSAPP_REPLY_SCHEDULE=Mon-Sat 6:00 AM-10:00 PM
WHATSAPP_REPLY_RENEW=Reply with your member code or visit the front desk to renew membership.
WHATSAPP_REPLY_STATUS_FOOTER=If this number is wrong, reply STOP and the team will update your record.
WHATSAPP_ADMIN_ALERT_PHONE=

# Campaign timing
WHATSAPP_DAILY_CRON=0 8 * * *
WHATSAPP_PROCESS_CRON=*/5 * * * *
WHATSAPP_MONTHLY_CRON=15 8 1 * *
WHATSAPP_EXPIRY_REMINDER_DAYS=3
WHATSAPP_REENGAGE_DAYS=14
WHATSAPP_INBOUND_RETRY_WINDOW_MINUTES=5
WHATSAPP_SEND_ATTEMPT_LIMIT=3
WHATSAPP_MESSAGE_THROTTLE_MS=1200

# Optional birthdays
WHATSAPP_BIRTHDAY_COLUMNS=date_of_birth,dob,birthday,birth_date
